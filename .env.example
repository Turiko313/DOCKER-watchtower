# ============================================================
# Watchtower + Dashboard – Environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Timezone ---
TZ=Europe/Paris

# --- Watchtower schedule (cron expression, 6 fields) ---
# Default: every day at 04:00
WATCHTOWER_SCHEDULE=0 0 4 * * *

# --- Hostname shown in notifications ---
WATCHTOWER_HOSTNAME=NAS-Watchtower

# --- Watchtower HTTP API token (random string, keep secret) ---
# Generate one with: openssl rand -hex 32
WATCHTOWER_API_TOKEN=change_me_watchtower_api_token

# --- Discord webhook notifications (shoutrrr format) ---
# Your Discord webhook URL looks like:
#   https://discord.com/api/webhooks/<webhook_id>/<webhook_token>
# Convert it to shoutrrr format:
#   discord://<webhook_token>@<webhook_id>
# Example:
#   DISCORD_NOTIFICATION_URL=discord://abcdefghij123456789@1234567890123456789
DISCORD_NOTIFICATION_URL=discord://your_webhook_token@your_webhook_id

# --- Dashboard credentials ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_strong_password

# --- Dashboard Flask secret key (random string, keep secret) ---
# Generate one with: openssl rand -hex 32
SECRET_KEY=change_me_flask_secret_key

# --- Dashboard port (accessible on LAN at http://<NAS_IP>:<port>) ---
DASHBOARD_PORT=8888
