# ============================================================
# Watchtower + Dashboard – Environment variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Timezone (system-level, applies to both containers) ---
TZ=Europe/Paris

# --- Watchtower HTTP API token (random string, keep secret) ---
# Generate one with: openssl rand -hex 32
WATCHTOWER_API_TOKEN=change_me_watchtower_api_token

# --- Dashboard credentials ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_strong_password

# --- Dashboard Flask secret key (random string, keep secret) ---
# Generate one with: openssl rand -hex 32
SECRET_KEY=change_me_flask_secret_key

# --- Dashboard port (accessible on LAN at http://<NAS_IP>:<port>) ---
DASHBOARD_PORT=8888

# ============================================================
# All other Watchtower options (schedule, cleanup, notifications,
# log level, rolling restart…) are configured directly in the
# dashboard Settings page and stored in the watchtower_config
# Docker volume.  No need to set them here.
# ============================================================
